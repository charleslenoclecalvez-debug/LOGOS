<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LOGOS — Galerie d'Art</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Montserrat:wght@200;300;400;500&display=swap" rel="stylesheet">
<style>
:root{--blanc:#FAFAF7;--beige:#E8E0D0;--beige-fonce:#C8B99A;--noir:#111110;--gris:#6B6B68;--or:#B8965A;}
*{margin:0;padding:0;box-sizing:border-box;}
body{background:var(--blanc);color:var(--noir);font-family:'Montserrat',sans-serif;font-weight:300;overflow-x:hidden;cursor:none;}
#cursor{width:10px;height:10px;background:var(--noir);border-radius:50%;position:fixed;pointer-events:none;z-index:99999;transform:translate(-50%,-50%);transition:width .3s,height .3s,background .3s;}
#cursor.grow{width:36px;height:36px;background:rgba(17,17,16,.12);}
nav{position:fixed;top:0;left:0;right:0;z-index:500;display:flex;align-items:center;justify-content:space-between;padding:24px 60px;background:rgba(250,250,247,.93);backdrop-filter:blur(12px);border-bottom:1px solid rgba(0,0,0,.06);}
.logo{font-family:'Cormorant Garamond',serif;font-size:26px;font-weight:300;letter-spacing:14px;text-transform:uppercase;color:var(--noir);text-decoration:none;}
.logo span{color:var(--or);}
.nav-links{display:flex;gap:40px;list-style:none;}
.nav-links a{font-size:10px;letter-spacing:3px;text-transform:uppercase;text-decoration:none;color:var(--gris);transition:color .3s;}
.nav-links a:hover{color:var(--noir);}
.nav-right{display:flex;align-items:center;gap:12px;}
.admin-badge{font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(--or);border:1px solid var(--or);padding:4px 12px;display:none;}
.admin-badge.visible{display:inline;}
.btn-outline{font-size:10px;letter-spacing:2px;text-transform:uppercase;background:none;border:1px solid var(--noir);color:var(--noir);padding:10px 20px;cursor:none;transition:all .3s;font-family:'Montserrat',sans-serif;font-weight:300;}
.btn-outline:hover{background:var(--noir);color:var(--blanc);}
.user-chip{display:none;align-items:center;gap:8px;font-size:10px;letter-spacing:1px;color:var(--gris);cursor:none;}
.user-chip.visible{display:flex;}
.user-avatar{width:30px;height:30px;border-radius:50%;background:var(--noir);display:flex;align-items:center;justify-content:center;color:var(--blanc);font-size:12px;font-weight:400;flex-shrink:0;}
.hero{min-height:100vh;display:flex;align-items:center;justify-content:center;flex-direction:column;position:relative;padding:0 60px;overflow:hidden;}
.hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 80% 60% at 70% 50%,var(--beige) 0%,transparent 70%);opacity:.5;}
.hero-eyebrow{font-size:10px;letter-spacing:5px;text-transform:uppercase;color:var(--beige-fonce);margin-bottom:28px;animation:fadeUp 1s ease both;}
.hero-title{font-family:'Cormorant Garamond',serif;font-size:clamp(72px,12vw,160px);font-weight:300;line-height:.9;text-align:center;letter-spacing:-2px;animation:fadeUp 1s ease .15s both;}
.hero-title em{font-style:italic;color:var(--gris);}
.hero-sub{font-size:11px;letter-spacing:3px;text-transform:uppercase;color:var(--gris);margin-top:32px;animation:fadeUp 1s ease .3s both;text-align:center;max-width:400px;line-height:2;}
.hero-line{width:1px;height:80px;background:var(--beige-fonce);margin-top:60px;animation:fadeUp 1s ease .5s both;}
@keyframes fadeUp{from{opacity:0;transform:translateY(30px)}to{opacity:1;transform:translateY(0)}}
.section-label{font-size:10px;letter-spacing:5px;text-transform:uppercase;color:var(--beige-fonce);margin-bottom:60px;display:flex;align-items:center;gap:20px;}
.section-label::before{content:'';display:block;width:40px;height:1px;background:var(--beige-fonce);}
.galerie-section{padding:100px 60px;background:var(--blanc);}
.galerie-header{display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:80px;}
.galerie-title{font-family:'Cormorant Garamond',serif;font-size:52px;font-weight:300;line-height:1.1;}
.galerie-title em{font-style:italic;color:var(--gris);}
.galerie-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:40px;}
.tableau-card{display:flex;flex-direction:column;animation:fadeUp .8s ease both;cursor:none;}
.tableau-card:nth-child(1){animation-delay:.05s}.tableau-card:nth-child(2){animation-delay:.12s}.tableau-card:nth-child(3){animation-delay:.19s}.tableau-card:nth-child(4){animation-delay:.26s}.tableau-card:nth-child(5){animation-delay:.33s}.tableau-card:nth-child(6){animation-delay:.4s}
.cadre-wrapper{position:relative;padding:18px;background:var(--beige);border:1px solid rgba(0,0,0,.08);box-shadow:0 0 0 1px rgba(0,0,0,.04),4px 4px 0 rgba(0,0,0,.03),8px 8px 20px rgba(0,0,0,.08),inset 0 0 0 3px rgba(255,255,255,.5);transition:transform .5s cubic-bezier(.25,.46,.45,.94),box-shadow .5s;aspect-ratio:3/4;overflow:hidden;}
.cadre-wrapper::before{content:'';position:absolute;inset:10px;border:1px solid rgba(0,0,0,.12);z-index:2;pointer-events:none;}
.cadre-wrapper::after{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(255,255,255,.3) 0%,transparent 50%,rgba(0,0,0,.05) 100%);z-index:3;pointer-events:none;}
.tableau-card:hover .cadre-wrapper{transform:translateY(-8px);box-shadow:0 0 0 1px rgba(0,0,0,.06),4px 4px 0 rgba(0,0,0,.04),16px 24px 40px rgba(0,0,0,.14),inset 0 0 0 3px rgba(255,255,255,.5);}
.tableau-placeholder{width:100%;height:100%;position:absolute;inset:0;display:flex;align-items:center;justify-content:center;}
.p1{background:linear-gradient(145deg,#2C3E50,#4A6741 40%,#8B7355)}.p2{background:linear-gradient(200deg,#D4A5A5,#9B8EA8 50%,#6B8CAE)}.p3{background:linear-gradient(120deg,#1a1a2e,#16213e 40%,#0f3460)}.p4{background:linear-gradient(160deg,#E8D5B7,#C4956A 50%,#8B6914)}.p5{background:linear-gradient(180deg,#2D4A3E,#588157 40%,#A7C4A0)}.p6{background:linear-gradient(130deg,#3D2B1F,#8B4513 50%,#D2691E)}
.overlay-btns{position:absolute;inset:18px;z-index:10;display:flex;align-items:flex-end;justify-content:center;padding-bottom:14px;gap:8px;opacity:0;transition:opacity .3s;}
.tableau-card:hover .overlay-btns{opacity:1;}
.view3d-btn{font-size:9px;letter-spacing:2px;text-transform:uppercase;background:rgba(250,250,247,.92);border:1px solid rgba(17,17,16,.25);color:var(--noir);padding:9px 16px;cursor:none;backdrop-filter:blur(6px);font-family:'Montserrat',sans-serif;font-weight:300;transition:all .2s;}
.view3d-btn:hover{background:var(--noir);color:var(--blanc);}
.tableau-info{padding:20px 0 0;display:flex;flex-direction:column;gap:6px;}
.tableau-artiste{font-size:9px;letter-spacing:3px;text-transform:uppercase;color:var(--beige-fonce);}
.tableau-nom{font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:300;font-style:italic;}
.tableau-bottom{display:flex;align-items:center;justify-content:space-between;margin-top:10px;}
.tableau-prix{font-size:16px;font-weight:400;letter-spacing:1px;}
.tableau-prix span{font-family:'Cormorant Garamond',serif;font-size:20px;}
.tableau-btn{font-size:9px;letter-spacing:2px;text-transform:uppercase;background:none;border:1px solid var(--noir);color:var(--noir);padding:8px 18px;cursor:none;transition:all .3s;font-family:'Montserrat',sans-serif;font-weight:300;}
.tableau-btn:hover{background:var(--noir);color:var(--blanc);}
.about-section{padding:100px 60px;display:grid;grid-template-columns:1fr 1fr;gap:100px;align-items:center;background:var(--noir);color:var(--blanc);}
.about-section .section-label{color:var(--beige-fonce);}
.about-section .section-label::before{background:var(--beige-fonce);}
.about-title-disp{font-family:'Cormorant Garamond',serif;font-size:52px;font-weight:300;line-height:1.1;margin-bottom:32px;}
.about-text-disp{font-size:13px;line-height:2.2;color:rgba(255,255,255,.6);font-weight:300;}
.about-visual{aspect-ratio:1;background:linear-gradient(145deg,#1a1a1a,#2a2a2a);border:1px solid rgba(255,255,255,.06);display:flex;align-items:center;justify-content:center;font-family:'Cormorant Garamond',serif;font-size:100px;font-weight:300;color:rgba(255,255,255,.04);letter-spacing:20px;}
.edit-about-btn{display:none;margin-top:18px;font-size:9px;letter-spacing:2px;text-transform:uppercase;background:none;border:1px solid rgba(255,255,255,.25);color:rgba(255,255,255,.5);padding:8px 18px;cursor:none;font-family:'Montserrat',sans-serif;font-weight:300;transition:all .3s;}
.edit-about-btn:hover{border-color:#fff;color:#fff;}
.edit-about-btn.visible{display:inline-block;}
footer{padding:60px;background:var(--noir);color:rgba(255,255,255,.3);display:flex;align-items:center;justify-content:space-between;border-top:1px solid rgba(255,255,255,.06);}
.footer-logo{font-family:'Cormorant Garamond',serif;font-size:20px;font-weight:300;letter-spacing:10px;color:rgba(255,255,255,.5);text-transform:uppercase;}
.footer-text{font-size:10px;letter-spacing:2px;}
/* MODALS */
.modal-overlay{position:fixed;inset:0;background:rgba(17,17,16,.72);backdrop-filter:blur(8px);z-index:1000;display:none;align-items:center;justify-content:center;opacity:0;transition:opacity .3s;}
.modal-overlay.active{display:flex;}
.modal-overlay.visible{opacity:1;}
.modal{background:var(--blanc);width:520px;max-width:92vw;max-height:90vh;overflow-y:auto;padding:52px;position:relative;border:1px solid var(--beige);transform:translateY(30px);transition:transform .4s cubic-bezier(.25,.46,.45,.94);}
.modal-overlay.visible .modal{transform:translateY(0);}
.modal-wide{width:680px;}
.modal-close{position:absolute;top:22px;right:26px;background:none;border:none;font-size:18px;cursor:none;color:var(--gris);transition:color .2s;}
.modal-close:hover{color:var(--noir);}
.modal-eyebrow{font-size:9px;letter-spacing:4px;text-transform:uppercase;color:var(--beige-fonce);margin-bottom:14px;}
.modal-title{font-family:'Cormorant Garamond',serif;font-size:34px;font-weight:300;margin-bottom:36px;line-height:1.1;}
.form-group{display:flex;flex-direction:column;gap:8px;margin-bottom:20px;}
.form-label{font-size:9px;letter-spacing:3px;text-transform:uppercase;color:var(--gris);}
.form-input{border:none;border-bottom:1px solid var(--beige);padding:12px 0;font-size:14px;font-family:'Montserrat',sans-serif;font-weight:300;background:transparent;color:var(--noir);outline:none;transition:border-color .3s;width:100%;}
.form-input:focus{border-color:var(--noir);}
.form-textarea{border:1px solid var(--beige);padding:14px;font-size:13px;font-family:'Montserrat',sans-serif;font-weight:300;background:transparent;color:var(--noir);outline:none;transition:border-color .3s;width:100%;resize:vertical;min-height:110px;line-height:1.8;}
.form-textarea:focus{border-color:var(--noir);}
.form-error{font-size:10px;color:#c0392b;letter-spacing:1px;display:none;}
.submit-btn{width:100%;background:var(--noir);color:var(--blanc);border:none;padding:16px;font-family:'Montserrat',sans-serif;font-size:10px;letter-spacing:3px;text-transform:uppercase;cursor:none;transition:background .3s;font-weight:300;margin-top:8px;}
.submit-btn:hover{background:#333;}
.auth-divider{display:flex;align-items:center;gap:16px;margin:24px 0;color:var(--beige-fonce);font-size:10px;letter-spacing:2px;text-transform:uppercase;}
.auth-divider::before,.auth-divider::after{content:'';flex:1;height:1px;background:var(--beige);}
.social-btns{display:flex;flex-direction:column;gap:10px;}
.social-btn{display:flex;align-items:center;gap:14px;border:1px solid var(--beige);padding:13px 20px;cursor:none;font-family:'Montserrat',sans-serif;font-size:11px;font-weight:300;letter-spacing:1px;background:var(--blanc);color:var(--noir);transition:all .3s;width:100%;}
.social-btn:hover{border-color:var(--noir);background:var(--noir);color:var(--blanc);}
.social-btn svg{width:18px;height:18px;flex-shrink:0;}
.social-btn:hover svg path{fill:#fff!important;}
.auth-switch{text-align:center;margin-top:22px;font-size:11px;color:var(--gris);}
.auth-switch a{color:var(--noir);text-decoration:underline;cursor:none;}
.admin-tabs{display:flex;border-bottom:1px solid var(--beige);margin-bottom:28px;}
.admin-tab{font-size:10px;letter-spacing:2px;text-transform:uppercase;padding:10px 16px;background:none;border:none;cursor:none;color:var(--gris);border-bottom:2px solid transparent;margin-bottom:-1px;font-family:'Montserrat',sans-serif;font-weight:300;transition:all .2s;}
.admin-tab.active{color:var(--noir);border-bottom-color:var(--noir);}
.tab-content{display:none;}
.tab-content.active{display:block;}
.prix-list{display:flex;flex-direction:column;max-height:280px;overflow-y:auto;}
.prix-item{display:flex;align-items:center;justify-content:space-between;padding:11px 0;border-bottom:1px solid var(--beige);}
.prix-item-nom{font-family:'Cormorant Garamond',serif;font-size:16px;font-style:italic;}
.prix-input-wrap{display:flex;align-items:center;gap:8px;}
.prix-currency{font-size:12px;color:var(--gris);}
.prix-input{border:1px solid var(--beige);padding:5px 8px;font-size:13px;font-family:'Montserrat',sans-serif;font-weight:300;width:80px;text-align:right;outline:none;background:var(--blanc);color:var(--noir);transition:border-color .2s;}
.prix-input:focus{border-color:var(--noir);}
.prix-save-btn{font-size:9px;letter-spacing:2px;text-transform:uppercase;background:var(--noir);color:var(--blanc);border:none;padding:5px 10px;cursor:none;font-family:'Montserrat',sans-serif;font-weight:300;}
.save-all-btn{margin-top:18px;background:none;border:1px solid var(--noir);color:var(--noir);padding:10px 22px;font-family:'Montserrat',sans-serif;font-size:10px;letter-spacing:3px;text-transform:uppercase;cursor:none;transition:all .3s;font-weight:300;}
.save-all-btn:hover{background:var(--noir);color:var(--blanc);}
.success-msg{font-size:10px;letter-spacing:2px;text-transform:uppercase;color:#27ae60;display:none;margin-top:12px;}
.success-msg.show{display:block;animation:fadeUp .4s ease;}
.upload-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.upload-card{border:1px solid var(--beige);padding:12px;display:flex;align-items:center;gap:10px;transition:border-color .2s;}
.upload-card:hover{border-color:var(--beige-fonce);}
.upload-num{font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:300;color:var(--beige-fonce);min-width:26px;}
.upload-card-info{flex:1;}
.upload-card-name{font-family:'Cormorant Garamond',serif;font-size:13px;font-style:italic;}
.upload-card-status{font-size:8px;letter-spacing:2px;text-transform:uppercase;color:var(--gris);margin-top:2px;}
.upload-file-btn{font-size:8px;letter-spacing:2px;text-transform:uppercase;background:none;border:1px solid var(--beige);padding:5px 8px;cursor:none;font-family:'Montserrat',sans-serif;color:var(--noir);transition:all .2s;}
.upload-file-btn:hover{border-color:var(--noir);}
input[type="file"]{display:none;}
.oeuvre-edit-row{border:1px solid var(--beige);padding:12px;margin-bottom:8px;display:grid;grid-template-columns:1fr 1fr 80px;gap:10px;align-items:end;}
.oeuvre-edit-row input{border:none;border-bottom:1px solid var(--beige);padding:5px 0;font-size:12px;font-family:'Montserrat',sans-serif;font-weight:300;background:transparent;color:var(--noir);outline:none;width:100%;}
.oeuvre-edit-row input:focus{border-bottom-color:var(--noir);}
.mini-label{font-size:8px;letter-spacing:2px;text-transform:uppercase;color:var(--gris);margin-bottom:4px;}
/* VIEWER 3D */
.viewer3d-overlay{position:fixed;inset:0;background:#080808;z-index:2000;display:none;flex-direction:column;opacity:0;transition:opacity .4s;}
.viewer3d-overlay.active{display:flex;}
.viewer3d-overlay.visible{opacity:1;}
.viewer3d-header{position:absolute;top:0;left:0;right:0;display:flex;align-items:center;justify-content:space-between;padding:22px 40px;z-index:10;background:linear-gradient(rgba(8,8,8,.8),transparent);}
.v3d-title{font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:300;font-style:italic;color:rgba(255,255,255,.75);}
.v3d-close{background:none;border:1px solid rgba(255,255,255,.2);color:rgba(255,255,255,.6);padding:7px 18px;font-family:'Montserrat',sans-serif;font-size:10px;letter-spacing:2px;text-transform:uppercase;cursor:none;transition:all .3s;}
.v3d-close:hover{border-color:#fff;color:#fff;}
.v3d-scene{flex:1;position:relative;}
#viewer3d{display:block;width:100%;height:100%;}
.v3d-hint{position:absolute;bottom:28px;left:50%;transform:translateX(-50%);font-size:9px;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,.25);}
.v3d-sidebar{position:absolute;right:40px;top:50%;transform:translateY(-50%);width:220px;display:flex;flex-direction:column;gap:8px;}
.v3d-artist{font-size:9px;letter-spacing:3px;text-transform:uppercase;color:rgba(255,255,255,.35);}
.v3d-nom{font-family:'Cormorant Garamond',serif;font-size:30px;font-weight:300;font-style:italic;color:rgba(255,255,255,.88);line-height:1.1;}
.v3d-prix{font-family:'Cormorant Garamond',serif;font-size:24px;color:var(--or);margin-top:6px;}
.v3d-acq{margin-top:14px;background:none;border:1px solid rgba(255,255,255,.25);color:rgba(255,255,255,.6);padding:10px 20px;font-family:'Montserrat',sans-serif;font-size:10px;letter-spacing:2px;text-transform:uppercase;cursor:none;transition:all .3s;display:inline-block;}
.v3d-acq:hover{border-color:#fff;color:#fff;}
/* USER DROPDOWN */
.user-dropdown-wrap{position:fixed;top:76px;right:60px;background:var(--blanc);border:1px solid var(--beige);box-shadow:0 12px 40px rgba(0,0,0,.1);z-index:600;display:none;min-width:170px;}
.user-dropdown-wrap.active{display:block;}
.udrop-item{display:block;width:100%;padding:10px 20px;font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--gris);background:none;border:none;cursor:none;text-align:left;font-family:'Montserrat',sans-serif;font-weight:300;transition:color .2s;}
.udrop-item:hover{color:var(--noir);}
.udrop-sep{height:1px;background:var(--beige);}
.toast{position:fixed;bottom:40px;right:60px;background:var(--noir);color:var(--blanc);padding:14px 26px;font-size:10px;letter-spacing:2px;text-transform:uppercase;z-index:9000;transform:translateY(80px);opacity:0;transition:all .4s cubic-bezier(.25,.46,.45,.94);}
.toast.show{transform:translateY(0);opacity:1;}
/* LOGGED IN SECTION */
.fav-empty{background:var(--beige);padding:18px;font-size:12px;color:var(--gris);font-style:italic;}
.logout-btn{background:none;border:1px solid var(--noir);color:var(--noir);padding:12px;font-family:'Montserrat',sans-serif;font-size:10px;letter-spacing:3px;text-transform:uppercase;cursor:none;transition:all .3s;font-weight:300;width:100%;margin-top:8px;}
.logout-btn:hover{background:var(--noir);color:var(--blanc);}
</style>
</head>
<body>
<div id="cursor"></div>
<div class="toast" id="toast"></div>
 
<nav>
  <a href="#" class="logo">LOG<span>O</span>S</a>
  <ul class="nav-links">
    <li><a href="#galerie">Collection</a></li>
    <li><a href="#about">À propos</a></li>
    <li><a href="#contact">Contact</a></li>
  </ul>
  <div class="nav-right">
    <span class="admin-badge" id="adminBadge">Admin</span>
    <div class="user-chip" id="userChip" onclick="toggleDropdown()">
      <div class="user-avatar" id="userAvatar">?</div>
      <span id="userName">—</span> ▾
    </div>
    <button class="btn-outline" id="openAccountBtn">Mon Compte</button>
    <button class="btn-outline" id="openAdminBtn" style="display:none">Dashboard</button>
  </div>
</nav>
 
<!-- USER DROPDOWN -->
<div class="user-dropdown-wrap" id="userDropdown">
  <button class="udrop-item" onclick="openMyAccount()">Mon profil</button>
  <div class="udrop-sep"></div>
  <button class="udrop-item" onclick="logout()" style="color:#c0392b">Se déconnecter</button>
</div>
 
<!-- HERO -->
<section class="hero">
  <div class="hero-eyebrow">Galerie d'Art en Ligne</div>
  <h1 class="hero-title">L'art<br><em>à portée</em><br>de regard</h1>
  <p class="hero-sub">Œuvres originales sélectionnées avec soin. Livraison en France et à l'international.</p>
  <div class="hero-line"></div>
</section>
 
<!-- GALERIE -->
<section class="galerie-section" id="galerie">
  <div class="galerie-header">
    <div>
      <div class="section-label">Collection actuelle</div>
      <h2 class="galerie-title">Nos <em>œuvres</em><br>à vendre</h2>
    </div>
  </div>
  <div class="galerie-grid" id="galerieGrid"></div>
</section>
 
<!-- ABOUT -->
<section class="about-section" id="about">
  <div>
