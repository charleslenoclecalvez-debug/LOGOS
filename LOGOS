<script>
/* DATA */
const T=[
  {id:0,nom:'Forêt Profonde', artiste:'Artiste Inconnu',annee:'2024',prix:1200,ico:'🎨',cls:'p1'},
  {id:1,nom:'Horizon Doux',   artiste:'Artiste Inconnu',annee:'2023',prix:850, ico:'🖼️',cls:'p2'},
  {id:2,nom:'Nuit Bleue',     artiste:'Artiste Inconnu',annee:'2024',prix:2400,ico:'🌊',cls:'p3'},
  {id:3,nom:"Lumière d'Or",   artiste:'Artiste Inconnu',annee:'2022',prix:3100,ico:'☀️',cls:'p4'},
  {id:4,nom:'Verdure Calme',  artiste:'Artiste Inconnu',annee:'2023',prix:980, ico:'🌿',cls:'p5'},
  {id:5,nom:'Terre Ancienne', artiste:'Artiste Inconnu',annee:'2024',prix:1750,ico:'🏛️',cls:'p6'},
];
const AU='admin', AP='logos2024';
let isAdmin=false, cUser=null;
const imgs={};
function fmt(n){return Number(n).toLocaleString('fr-FR');}
 
function loadData(){
  T.forEach(t=>{
    const p=localStorage.getItem('lp'+t.id); if(p)t.prix=+p;
    const n=localStorage.getItem('ln'+t.id); if(n)t.nom=n;
    const a=localStorage.getItem('la'+t.id); if(a)t.artiste=a;
    const y=localStorage.getItem('ly'+t.id); if(y)t.annee=y;
    const img=localStorage.getItem('li'+t.id); if(img)imgs[t.id]=img;
  });
  const at=localStorage.getItem('labout-t'),ab=localStorage.getItem('labout-b');
  if(at)document.getElementById('aboutTitle').innerHTML=at;
  if(ab)document.getElementById('aboutText').textContent=ab;
  const u=localStorage.getItem('lcuser'); if(u){cUser=JSON.parse(u);applyUser();}
}
 
/* CURSOR */
const cur=document.getElementById('cursor');
document.addEventListener('mousemove',e=>{cur.style.left=e.clientX+'px';cur.style.top=e.clientY+'px';});
document.addEventListener('click',()=>document.getElementById('userDropdown').classList.remove('active'));
function attachCursors(){document.querySelectorAll('a,button,label,.tableau-card,.user-chip').forEach(el=>{el.addEventListener('mouseenter',()=>cur.classList.add('grow'));el.addEventListener('mouseleave',()=>cur.classList.remove('grow'));});}
 
/* GALLERY */
function buildGallery(){
  const g=document.getElementById('galerieGrid'); g.innerHTML='';
  T.forEach(t=>{
    const hi=!!imgs[t.id];
    const inner=hi
      ?`<div style="width:100%;height:100%;position:absolute;inset:0;background:url(${imgs[t.id]}) center/cover"></div>`
      :`<div class="tableau-placeholder ${t.cls}" style="width:100%;height:100%;position:absolute;inset:0;display:flex;align-items:center;justify-content:center;"><span style="opacity:.15;font-size:48px">${t.ico}</span></div>`;
    g.innerHTML+=`<div class="tableau-card">
      <div class="cadre-wrapper" style="position:relative;"><div id="img-${t.id}">${inner}</div>
      <div class="overlay-btns"><button class="view3d-btn" onclick="openV3D(${t.id})">⬡ Vue 3D</button></div></div>
      <div class="tableau-info">
        <div class="tableau-artiste" id="art-d${t.id}">${t.artiste} · ${t.annee}</div>
        <div class="tableau-nom" id="nom-d${t.id}">${t.nom}</div>
        <div class="tableau-bottom">
          <div class="tableau-prix"><span id="px-d${t.id}">${fmt(t.prix)}</span> €</div>
          <button class="tableau-btn" onclick="showToast('Ajouté — ${t.nom.replace(/'/g,"\\'")} ✓')">Acquérir</button>
        </div>
      </div></div>`;
  });
  attachCursors();
  document.querySelectorAll('.tableau-card').forEach(c=>{c.style.animationPlayState='paused';obs.observe(c);});
}
 
/* MODAL HELPERS */
function openModal(id){const o=document.getElementById(id);o.classList.add('active');setTimeout(()=>o.classList.add('visible'),10);}
function closeModal(id){const o=document.getElementById(id);o.classList.remove('visible');setTimeout(()=>o.classList.remove('active'),300);}
document.querySelectorAll('.modal-overlay').forEach(o=>o.addEventListener('click',e=>{if(e.target===o)closeModal(o.id);}));
function showToast(m){const t=document.getElementById('toast');t.textContent=m;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),2600);}
function showOk(id){const s=document.getElementById(id);s.classList.add('show');setTimeout(()=>s.classList.remove('show'),2500);}
 
/* AUTH */
document.getElementById('openAccountBtn').addEventListener('click',()=>{
  if(cUser){toggleDropdown();}else{switchAuth('login');openModal('accountOverlay');}
});
function toggleDropdown(e){if(e)e.stopPropagation();document.getElementById('userDropdown').classList.toggle('active');}
document.getElementById('userChip').addEventListener('click',toggleDropdown);
 
function switchAuth(v){
  document.getElementById('viewLogin').style.display=v==='login'?'block':'none';
  document.getElementById('viewRegister').style.display=v==='register'?'block':'none';
  document.getElementById('viewLoggedIn').style.display=v==='logged'?'block':'none';
}
function socialLogin(p){
  loginUser({name:'Utilisateur '+p,email:p.toLowerCase()+'@logos.fr'});
  closeModal('accountOverlay');
  showToast('Connecté via '+p+' ✓');
}
function emailLogin(){
  const e=document.getElementById('loginEmail').value.trim(),p=document.getElementById('loginPwd').value,err=document.getElementById('loginErr');
  const users=JSON.parse(localStorage.getItem('lusers')||'[]');
  const f=users.find(u=>u.email===e&&u.pass===p);
  if(!f){err.style.display='block';return;}err.style.display='none';
  loginUser(f);closeModal('accountOverlay');showToast('Bienvenue '+f.name+' ✓');
}
function emailRegister(){
  const n=document.getElementById('regName').value.trim(),e=document.getElementById('regEmail').value.trim(),p=document.getElementById('regPwd').value,err=document.getElementById('regErr');
  if(!n||!e||p.length<6){err.style.display='block';return;}err.style.display='none';
  const users=JSON.parse(localStorage.getItem('lusers')||'[]');
  users.push({name:n,email:e,pass:p});localStorage.setItem('lusers',JSON.stringify(users));
  loginUser({name:n,email:e});closeModal('accountOverlay');showToast('Compte créé — Bienvenue '+n+' ✓');
}
function loginUser(u){cUser=u;localStorage.setItem('lcuser',JSON.stringify(u));applyUser();}
function applyUser(){
  document.getElementById('userChip').classList.add('visible');
  document.getElementById('userAvatar').textContent=cUser.name.charAt(0).toUpperCase();
  document.getElementById('userName').textContent=cUser.name.split(' ')[0];
  document.getElementById('openAccountBtn').style.display='none';
  document.getElementById('loggedInTitle').textContent='Bonjour, '+cUser.name.split(' ')[0]+' 👋';
  attachCursors();
}
function logout(){cUser=null;localStorage.removeItem('lcuser');document.getElementById('userChip').classList.remove('visible');document.getElementById('openAccountBtn').style.display='inline-block';closeModal('accountOverlay');document.getElementById('userDropdown').classList.remove('active');showToast('Déconnecté');}
function openMyAccount(){switchAuth('logged');openModal('accountOverlay');document.getElementById('userDropdown').classList.remove('active');}
 
/* ADMIN */
document.getElementById('openAdminBtn').addEventListener('click',()=>openModal('adminOverlay'));
function adminLogin(){
  const u=document.getElementById('adminUser').value.trim(),p=document.getElementById('adminPass').value;
  if(u===AU&&p===AP){
    document.getElementById('adminErr').style.display='none';
    document.getElementById('adminLoginSection').style.display='none';
    document.getElementById('adminPanelSection').style.display='block';
    document.getElementById('adminBadge').classList.add('visible');
    document.getElementById('openAdminBtn').style.display='inline-block';
    document.getElementById('editAboutBtn').classList.add('visible');
    isAdmin=true; buildAdminPanel(); showToast('Accès admin accordé');
  }else{document.getElementById('adminErr').style.display='block';document.getElementById('adminPass').value='';}
}
 
function buildAdminPanel(){
  // PRIX
  const pl=document.getElementById('prixList'); pl.innerHTML='';
  T.forEach(t=>{
    const r=document.createElement('div');r.className='prix-item';
    r.innerHTML=`<div class="prix-item-nom">${t.nom}</div>
    <div class="prix-input-wrap"><span class="prix-currency">€</span>
    <input type="number" class="prix-input" id="ap${t.id}" value="${t.prix}" min="0">
    <button class="prix-save-btn" onclick="savePrix(${t.id})">OK</button></div>`;
    pl.appendChild(r);
  });
  // OEUVRES
  const ol=document.getElementById('oeuvrEditList'); ol.innerHTML='';
  T.forEach(t=>{
    ol.innerHTML+=`<div class="oeuvre-edit-row">
      <div><div class="mini-label">Titre</div><input id="an${t.id}" value="${t.nom}"></div>
      <div><div class="mini-label">Artiste</div><input id="aa${t.id}" value="${t.artiste}"></div>
      <div><div class="mini-label">Année</div><input id="ay${t.id}" value="${t.annee}"></div>
    </div>`;
  });
  // HISTOIRE
  document.getElementById('adminAboutTitle').value=document.getElementById('aboutTitle').innerText||'';
  document.getElementById('adminAboutText').value=document.getElementById('aboutText').textContent||'';
  // PHOTOS
  const ug=document.getElementById('uploadGrid'); ug.innerHTML='';
  T.forEach(t=>{
    const c=document.createElement('div');c.className='upload-card';
    c.innerHTML=`<div class="upload-num">0${t.id+1}</div>
    <div class="upload-card-info"><div class="upload-card-name">${t.nom}</div>
    <div class="upload-card-status" id="us${t.id}">${imgs[t.id]?'Photo ajoutée ✓':'En attente'}</div></div>
    <label class="upload-file-btn" for="fi${t.id}">Photo</label>
    <input type="file" id="fi${t.id}" accept="image/*" onchange="handleUpload(event,${t.id})">`;
    ug.appendChild(c);
  });
  attachCursors();
}
 
document.querySelectorAll('.admin-tab').forEach(tab=>{
  tab.addEventListener('click',()=>{
    document.querySelectorAll('.admin-tab').forEach(t=>t.classList.remove('active'));
    document.querySelectorAll('.tab-content').forEach(c=>c.classList.remove('active'));
    tab.classList.add('active');document.getElementById('tab-'+tab.dataset.tab).classList.add('active');
  });
});
 
function savePrix(id){
  const v=parseFloat(document.getElementById('ap'+id).value);
  if(isNaN(v)||v<0)return;
  T[id].prix=v;localStorage.setItem('lp'+id,v);
  const el=document.getElementById('px-d'+id);if(el)el.textContent=fmt(v);
  showToast('Prix mis à jour — '+T[id].nom);
}
function saveAllPrix(){T.forEach(t=>savePrix(t.id));showOk('okPrix');}
function saveOeuvres(){
  T.forEach(t=>{
    const n=document.getElementById('an'+t.id)?.value||t.nom;
    const a=document.getElementById('aa'+t.id)?.value||t.artiste;
